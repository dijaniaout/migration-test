<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="customisable_workflow_view_form" model="ir.ui.view">
            <field name="name">customisable_workflow.form</field>
            <field name="model">customisable_workflow.dunning.rule</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Libellé ..."  widget="text"/>
                        </h1>
                    </div>
                        <group>
                            <group>
                                <field name="field_id"/>
                                <field name="sign"/>
                            </group>
                            <group>
                                <field name="value_type" invisible="1"/>
                                <field name="number" readonly="sign in ('is_defined','is_not_defined')" invisible="value_type == 'boolean'" />
                                <field name="boolean_value" readonly="sign in ('is_defined','is_not_defined')" invisible="value_type != 'boolean'" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="customisable_workflow_view_tree" model="ir.ui.view">
            <field name="name">customisable_workflow.tree</field>
            <field name="model">customisable_workflow.dunning.rule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="field_id"/>
                    <field name="sign"/>
                </list>
            </field>
        </record>

        <record id="customisable_workflow_dunning" model="ir.actions.act_window">
            <field name="name">Règles de relance</field>
            <field name="res_model">customisable_workflow.dunning.rule</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem 
        id="customisable_workflow_menu" 
        name="Règles de relance" 
        parent="menu_customisable_workflow_configuration" 
        action="customisable_workflow_dunning" />
    </data>
</odoo>