<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="customisable_workflow_workflow_view" model="ir.ui.view">
            <field name="name">customisable_workflow.workflow.form</field>
            <field name="model">customisable_workflow.workflow</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group name="main">
                            <group>
                                <field name="processing_time_feature_enabed" invisible="1"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="type" widget="radio" options="{'horizontal': false}"/>
                                <field name="start_step_id" invisible="type == 'subprocess'"/>
                                <field name="subprocess_id" invisible="type == 'process'"/>
                                <field name="res_model_id" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Etapes du processus" name="workflow_step">
                                <field name="step_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="provided_document_ids" widget="many2many_tags" string="Documents à fournir"/>
                                        <field name="generated_document_ids" widget="many2many_tags" string="Documents à générer"/>
                                        <field name="notification_type_ids" widget="many2many_tags"/>
                                        <field name="allowed_user_ids" widget="many2many_tags"/>
                                        <field name="allowed_group_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Gestion du temps">
                                <group>
                                    <group>
                                        <field name="maximum_processing_time"/>
                                        <field name="processing_start_step_id" required="processing_time_feature_enabed == True"/>
                                    </group>
                                    <group>
                                        <field name="processing_expiraton_step_id" required="processing_time_feature_enabed == True"/>
                                        <field name="processing_end_step_id" required="processing_time_feature_enabed == True"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Visibilités champs par étape">
                                <field name="field_step_visibility_ids">
                                    <list editable="top">
                                        <field name="field_id" domain="[('model_id', '=', res_model_id)]"/>
                                        <field name="required_step_id" domain="[('workflow_id', '=', workflow_id)]"/>
                                        <field name="readonly_step_id" domain="[('workflow_id', '=', workflow_id)]"/>
                                        <field name="visible_step_id" domain="[('workflow_id', '=', workflow_id)]"/>
                                        <field name="workflow_id" column_invisible="True"/>
                                        <field name="res_model_id" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                            <page name="dunning_rules" string="Relances">
                                <field name="dunning_ids">
                                    <list editable="bottom">
                                        <field name="name" />
                                        <field name="dunning_rule_ids" widget="many2many_tags" />
                                        <field name="cumulative" />
                                        <field name="notification_ids" widget="many2many_tags" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                  </form>
            </field>
        </record>

        <record id="customisable_workflow_workflow_view_tree" model="ir.ui.view">
            <field name="name">customisable_workflow.workflow.tree</field>
            <field name="model">customisable_workflow.workflow</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="subprocess_id" />
                    <field name="start_step_id" />
                </list>
            </field>
        </record>

        <record id="customisable_workflow_workflow" model="ir.actions.act_window">
            <field name="name">Processus</field>
            <field name="res_model">customisable_workflow.workflow</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        <menuitem name="Processus" id="workflow_menu" parent="menu_customisable_workflow_configuration"
            action="customisable_workflow_workflow" sequence="1"/>  

    </data>
</odoo>