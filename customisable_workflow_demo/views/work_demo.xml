<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="customisable_workflow_demo_work_demo_view" model="ir.ui.view">
            <field name="name">customisable_workflow_demo.work_demo.form</field>
            <field name="model">customisable_workflow_demo.work_demo</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <!-- Note: Next button is added in the fields_view_get -->
                        <field name="current_user_can_act" invisible='1'/>
                        <field name="has_documents_to_give" invisible="1"/>
                        <field name="has_documents_to_generate" invisible="1"/>
                        <field name="current_step_id" invisible="1"/>
                        <field name="visible_step" invisible="1"/>
                        <field name="done_step_ids" invisible="1"/>
                        <field name="has_document_to_check" invisible="1"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="has_a_justification" invisible="1"/>
                            <div class="alert alert-warning o_account_followup-no-action" role="alert" invisible="has_a_justification == False">
                                <field name="justification" style="font-weight: bold;"/>
                            </div>
                        </group>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" class="oe_inline"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="workflow_id"/>
                                <field name="is_not_editable" invisible='1'/>
                            </group>
                            <group>
                                <field name="description"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="documents-events" string="Documents">
                                <field name="document_event_ids" widget="document_event_widget"/>
                            </page>
                            <page name="decision" string="Historique des étapes">
                                <field name="transition_history_ids" readonly="1">
                                    <kanban create="false" sample="1" class="o_field_widget o_step_history_kanban" >
                                        <templates>
                                            <t t-name="card">
                                                <div class="o_arrow_button oe_kanban_details d-flex justify-content-between flex-column">
                                                    <div class="o_kanban_details_wrapper">
                                                        <field name="step_to_id"/>
                                                    </div>
                                                    <div class="o_justification" invisible="justification == False">
                                                        <b>Justification: </b><field name="justification"/>
                                                    </div>
                                                    <div class="o_kanban_record_bottom">
                                                        <div class="oe_kanban_bottom_left">
                                                            <field name="date" widget="date"/>
                                                        </div>
                                                        <div class="oe_kanban_bottom_right">
                                                            <field name="user_id" widget="many2one_avatar_user" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                            <page string="Checklists" invisible="not has_document_to_check">
                                <field name="checklist_response_ids">
                                    <list editable="bottom" create="0" delete="0" >
                                        <field name="document_id"/>
                                        <field name="checklist_id"/>
                                        <field name="current_user_can_not_edit_checker" invisible="1"/>
                                        <field name="checker_ids" widget="many2many_tags" readonly="current_user_can_not_edit_checker or state != 'draft'"/>
                                        <field name="state" readonly="1"/>
                                        <field name="attachment_ids" widget="many2many_binary" readonly="state != 'draft'"/>
                                        <button
                                            string="Evaluer"
                                            type="object"
                                            name="open_one2many_line"
                                            context="{'default_active_id': id}"
                                            icon="fa-edit">
                                        </button>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <!-- Chatter -->
                    <chatter/>
                  </form>
            </field>
        </record>

        <record id="customisable_workflow_demo_work_demo_view_tree" model="ir.ui.view">
            <field name="name">customisable_workflow_demo.work_demo.tree</field>
            <field name="model">customisable_workflow_demo.work_demo</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="workflow_id"/>
                    <field name="visible_step"/>
                </list>
            </field>
        </record>

        <record id="customisable_workflow_demo_work_demo" model="ir.actions.act_window">
            <field name="name">Demo Travail</field>
            <field name="res_model">customisable_workflow_demo.work_demo</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        <menuitem name="Demo Travail" id="workflow_work_demo_menu" parent="customisable_workflow.menu_customisable_workflow_configuration"
            action="customisable_workflow_demo_work_demo"/>  

    </data>
</odoo>