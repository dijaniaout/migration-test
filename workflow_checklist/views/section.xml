<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="workflow_checklist_section_view_form" model="ir.ui.view">
            <field name="name">workflow_checklist.section.form</field>
            <field name="model">workflow_checklist.section</field>
            <field name="arch" type="xml">
                <form create="false" edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="parent_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="checks" string="Checks">
                                <field name="check_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="maximum_number_of_points"/>
                                        <field name="type_response"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="workflow_checklist_section_view_tree" model="ir.ui.view">
            <field name="name">workflow_checklist.section.tree</field>
            <field name="model">workflow_checklist.section</field>
            <field name="arch" type="xml">
                <list create="false" edit="false">
                    <field name="name"/>
                    <field name="parent_id"/>
                    <field name="checklist_id"/>
                </list>
            </field>
        </record>

        <record id="workflow_checklist_section" model="ir.actions.act_window">
            <field name="name">Section</field>
            <field name="res_model">workflow_checklist.section</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

       <menuitem name="Sections" id="menu_workflow_checklist_section" parent="workflow_checklist.menu_workflow_checklist"
                action="workflow_checklist_section" sequence="2"/>
    </data>
</odoo>