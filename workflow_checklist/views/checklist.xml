<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="workflow_checklist_checklist_view_form" model="ir.ui.view">
            <field name="name">workflow_checklist.checklist.form</field>
            <field name="model">workflow_checklist.checklist</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="checker_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="section" string="Section">
                                <field name="section_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="parent_id"/>
                                    </list>
                                </field>
                            </page>
                             <page name="note_decision" string="Décision sur la note">
                                <field name="note_decision_ids">
                                    <list editable="bottom">
                                        <field name="start_of_interval"/>
                                        <field name="end_of_interval"/>
                                        <field name="decision"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                  </form>
            </field>
        </record>

        <record id="workflow_checklist_checklist_view_tree" model="ir.ui.view">
            <field name="name">workflow_checklist.checklist.tree</field>
            <field name="model">workflow_checklist.checklist</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="checklist_workflow_checklist" model="ir.actions.act_window">
            <field name="name">Checklist</field>
            <field name="res_model">workflow_checklist.checklist</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

       <menuitem name="Checklist" id="menu_checklist_workflow_checklist" parent="workflow_checklist.menu_workflow_checklist"
                action="checklist_workflow_checklist" sequence="1"/> 
    </data>
</odoo>