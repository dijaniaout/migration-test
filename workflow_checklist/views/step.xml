<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="inherit_customisable_workflow_step_view_form" model="ir.ui.view">
            <field name="name">inherit.customisable_workflow.form</field>
            <field name="model">customisable_workflow.step</field>
            <field name="type">form</field>
            <field name="inherit_id" ref="customisable_workflow.customisable_workflow_step_view_form"/>
            <field name="arch" type="xml">
                <field name="provided_document_ids" position="after">
                    <field name="document_to_check_ids" help="Pour appliquer un checklist au dossier, veuillez ne pas selectionner de document !">
                        <list editable="bottom">
                            <field name="checklist_ids" widget="many2many_tags"/>
                            <field name="document_id"/>
                        </list>
                    </field>
                </field>
            </field>
        </record>
    </data>
</odoo>