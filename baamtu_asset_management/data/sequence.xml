<odoo>

    <record id="seq_asset_imo" model="ir.sequence">
        <field name="name">Asset IMO Sequence</field>
        <field name="code">asset.imo.sequence</field>
        <field name="prefix"></field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_asset_inventory" model="ir.sequence">
        <field name="name">Asset Inventory</field>
        <field name="code">asset.inventory</field>
        <field name="prefix">INV/AST/</field>
        <field name="padding">4</field>
    </record>

</odoo>
