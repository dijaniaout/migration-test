<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    
        <!-- list -->
        <record id="view_asset_inventory_list" model="ir.ui.view">
            <field name="name">asset.inventory.list</field>
            <field name="model">asset.inventory</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="site_id"/>
                </list>
            </field>
        </record>

        <record id="view_asset_inventory_form" model="ir.ui.view">
            <field name="name">asset.inventory.form</field>
            <field name="model">asset.inventory</field>
            <field name="arch" type="xml">
                <form>
                        <header>
                            <field name="current_user_can_act" invisible="1"/>
                            <field name="has_documents_to_give" invisible="1"/>
                            <field name="has_documents_to_generate" invisible="1"/>
                            <field name="current_step_id" widget="statusbar" invisible="1"/>
                            <field name="has_a_justification" invisible="1"/>
                            <field name="visible_step" invisible="1"/>
                        </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="site_id"/>
                                <field name="workflow_id" force_save="1" />
                                <field name="is_not_editable" invisible="1"/>
                            </group>

                            <group>
                                <field name="employee_id"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Site">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="asset_code"/>
                                        <field name="asset_id"/>
                                        <field name="model_id"/>
                                        <field name="acquisition_date"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_asset_inventory" model="ir.actions.act_window">
            <field name="name">Inventaires</field>
            <field name="res_model">asset.inventory</field>
            <field name="view_mode">list,form</field>
        </record>
        
    </data>
    
</odoo>
