<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    
        <!-- list -->
        <record id="view_asset_floor_list" model="ir.ui.view">
            <field name="name">asset.floor.list</field>
            <field name="model">asset.floor</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="site_id"/>
                </list>
            </field>
        </record>

        <!-- FORM -->
        <record id="view_asset_floor_form" model="ir.ui.view">
            <field name="name">asset.floor.form</field>
            <field name="model">asset.floor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                            </group>
                            <group>
                                <field name="site_id" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_asset_floor" model="ir.actions.act_window">
            <field name="name">Etages</field>
            <field name="res_model">asset.floor</field>
            <field name="view_mode">list,form</field>
        </record>
    
    </data>
    

</odoo>
