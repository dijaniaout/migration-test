<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sn_administrative_division_department_tree" model="ir.ui.view">
            <field name="name">sn_administrative_division.department.tree</field>
            <field name="model">sn_administrative_division.department</field>
            <field name="arch" type="xml">
                <list string="Départements territoriaux">
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record id="sn_administrative_division_department_form" model="ir.ui.view">
            <field name="name">sn_administrative_division.department.form</field>
            <field name="model">sn_administrative_division.department</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="region_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Communes">
                                <field name="municipality_ids">
                                    <list>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>                       
                    </sheet>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="sn_administrative_division_department_list_action">
            <field name="name">Départements</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sn_administrative_division.department</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem name="Départements" id="sn_administrative_division_department_menu" parent="sn_administrative_division.menu_configuration"
              action="sn_administrative_division_department_list_action"/>   
    </data>
</odoo>