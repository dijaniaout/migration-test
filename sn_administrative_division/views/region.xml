<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sn_administrative_division_region_tree" model="ir.ui.view">
            <field name="name">sn_administrative_division.region.tree</field>
            <field name="model">sn_administrative_division.region</field>
            <field name="arch" type="xml">
                <list string="Régions">
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record id="sn_administrative_division_region_form" model="ir.ui.view">
            <field name="name">sn_administrative_division.region.form</field>
            <field name="model">sn_administrative_division.region</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Départements">
                                <field name="department_ids">
                                    <list>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>                       
                    </sheet>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="sn_administrative_division_region_list_action">
            <field name="name">Régions</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sn_administrative_division.region</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem name="Régions" id="sn_administrative_division_region_menu" parent="sn_administrative_division.menu_configuration"
        action="sn_administrative_division_region_list_action"/>  
    </data>
</odoo>