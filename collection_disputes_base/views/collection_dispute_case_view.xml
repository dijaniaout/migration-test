<odoo>
   <data>
   
    <record id="view_collection_dispute_case_form" model="ir.ui.view">
        <field name="name">collection.dispute.case.form</field>
        <field name="model">collection.dispute.case</field>
        <field name="arch" type="xml">
            <form string="Recouvrement" create="true" edit="true">
                <!-- Header section -->
                <header>
                    <field name="current_user_can_act" invisible="1"/>
                    <field name="has_documents_to_give" invisible="1"/>
                    <field name="has_documents_to_generate" invisible="1"/>
                    <field name="current_step_id" widget="statusbar" invisible="1"/>
                    <field name="has_a_justification" invisible="1"/>
                    <field name="visible_step" invisible="1"/>
                </header>

                <!-- Sheet body -->
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_amortization_lines"
                                class="oe_stat_button"
                                icon="fa-table"
                                string="Échéances / Paiements">
                            <field name="amortization_line_ids" widget="statinfo" stat="len"/>
                        </button>
                        <button type="object"
                                name="action_open_legal_dispute"
                                class="oe_stat_button"
                                icon="fa-gavel"
                                string="Litiges">
                            <field name="legal_dispute_ids" widget="statinfo" stat="len"/>
                        </button>

                        <button type="object"
                                name="action_open_judicial_decision"
                                class="oe_stat_button"
                                icon="fa-balance-scale"
                                string="Décisions de justice" style="margin-left: 8px;">
                            <field name="judicial_decision_ids" widget="statinfo" stat="len"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <field name="has_a_justification" invisible="1"/>
                        <div class="alert alert-warning o_account_followup-no-action" role="alert"
                            invisible="has_a_justification == False">
                            <field name="justification" style="font-weight: bold;" readonly="1"/>
                        </div>
                        <h1>
                            <field name="name" placeholder="Intitulé du projet ..." widget="text"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="base_workflow_id" force_save="1" invisible="1"/>
                            <field name="customer_id"/>
                            <field name="workflow_id" force_save="1" readonly="1"/>
                            <field name="project_code"/>
                            <field name="creation_date"/>
                            <field name="currency_id" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="country_id"
                                options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="is_not_editable" invisible="1"/>
                            <field name="case_manager_id"/>
                            <field name="substitute_id"/>
                            <field name="justice_auxiliary_ids" widget="many2many_tags"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                    <!-- Onglets -->
                    <notebook>
                        <page string="Informations">
                            <group string="Informations sur le prêt">
                                <group>
                                    <field name="loan_amount"/>
                                    <field name="loan_duration"/>
                                </group>
                                <group>
                                    <field name="interest_rate"/>
                                    <field name="late_interest_rate"/>
                                </group>
                            </group>

                            <group string="Suivi du recouvrement">
                                <group>
                                    <field name="settlement_total_due" readonly="1"/>
                                    <field name="amount_to_recover_agreement" readonly="1"/>
                                    <field name="unpaid_count"/>
                                    <field name="off_balance_sheet" widget="boolean_toggle"/>
                                </group>
                                <group>
                                    <field name="remaining_amount" readonly="1"/>
                                    <field name="total_recovered"/> 
                                    <field name="remaining_amount_to_recover" readonly="1"/>
                                    <field name="amount_unrecoverable" readonly="1"/>
                                </group>
                            </group>

                            <group string="Frais">
                                <group>
                                    <field name="total_honorary" readonly="1"/>
                                    <field name="total_procedure_fee" readonly="1"/>
                                </group>
                                <group>
                                    <field name="total_additional_fees" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Frais annexes">
                            <field name="additional_fee_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="fee_type"/>
                                    <field name="auxiliary_id" invisible="fee_type == 'procedure'"/>
                                    <field name="attachment_ids" widget="many2many_binary"/>
                                </list>
                            </field>
                        </page>

                        <page name="interventions_ids" string="Interventions">
                            <div class="row">
                                <div class="o_hr_skills_group o_group_resume col-12 d-flex flex-column">
                                    <field name="justice_intervention_ids"
                                        widget="resume_one2many"
                                        mode="list"
                                        nolabel="1"
                                        options="{'create_text': 'Créer une nouvelle intervention'}">
                                        <list>
                                            <field name="line_type_id"/>
                                            <field name="name"/>
                                            <field name="date_start"/>
                                            <field name="date_end"/>
                                            <field name="description"/>
                                            <field name="display_type" invisible="1"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </page>

                        <page string="Arrêtés de créance">
                            <field name="settlement_ids"/>
                        </page>

                        <page string="Accords transactionnels">
                            <field name="transaction_agreement_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="settlement_statement_id"/>
                                </list>
                            </field>
                        </page>

                        <page name="documents-events" string="Documents">
                            <field name="document_event_ids" readonly="1" widget="document_event_widget"/>
                        </page>

                        <page name="decision" string="Historique des étapes">
                            <field name="transition_history_ids" readonly="1">
                                <kanban create="false" sample="1" class="o_field_widget o_step_history_kanban">
                                    <templates>
                                        <t t-name="card">
                                            <div class="o_arrow_button oe_kanban_details d-flex justify-content-between flex-column">
                                                <div class="o_kanban_details_wrapper">
                                                    <field name="workflow_id"/>
                                                </div>
                                                <div class="o_kanban_details_wrapper">
                                                    <field name="step_to_id"/>
                                                </div>
                                                <div class="o_kanban_record_bottom">
                                                    <div class="oe_kanban_bottom_left">
                                                        <field name="date" widget="date"/>
                                                    </div>
                                                    <div class="oe_kanban_bottom_right">
                                                        <field name="user_id" widget="many2one_avatar_user"/>
                                                    </div>
                                                </div>
                                                <div class="o_kanban_details_wrapper"
                                                    attrs="{'invisible': [('justification', '=', False)]}">
                                                    <span>justification: </span>
                                                    <field name="justification"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_collection_dispute_case_tree" model="ir.ui.view">
        <field name="name">collection.dispute.case.list</field>
        <field name="model">collection.dispute.case</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="project_code" />
                <field name="customer_id" />
                <field name="country_id" />
                <field name="creation_date" />
                <field name="case_manager_id"/>
                <field name="substitute_id"/>
                <field name="workflow_id" />
                <field name="current_step_id" />
            </list>
        </field>
    </record>

    <!-- ====== KANBAN ====== -->
    <record id="view_collection_dispute_case_kanban" model="ir.ui.view">
      <field name="name">collection.dispute.case.kanban</field>
      <field name="model">collection.dispute.case</field>
      <field name="arch" type="xml">
        <kanban default_group_by="case_manager_id" class="o_kanban_small_column">
          <templates>
            <t t-name="card">
              <div class="oe_kanban_global_click o_kanban_record">
                <div class="o_kanban_primary_left">
                  <strong><field name="name"/></strong>
                  <div>
                    <span><field name="project_code"/></span>
                  </div>
                  <div>
                    <span t-esc="'Étape:'"/> <field name="current_step_id"/>
                  </div>
                </div>
                <div class="o_kanban_primary_right">
                  <div><field name="case_manager_id" widget="many2one_avatar_user"/></div>
                  <div class="text-muted"><field name="creation_date"/></div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

 <!-- ====== CALENDAR ====== -->
    <record id="view_collection_dispute_case_calendar" model="ir.ui.view">
      <field name="name">collection.dispute.case.calendar</field>
      <field name="model">collection.dispute.case</field>
      <field name="arch" type="xml">
        <!-- On utilise creation_date comme point d'entrée calendrier -->
        <calendar string="Recouvrements" date_start="creation_date" color="case_manager_id">
          <field name="name"/>
          <field name="case_manager_id"/>
          <field name="customer_id"/>
        </calendar>
      </field>
    </record>

    <!-- ====== PIVOT ====== -->
    <record id="view_collection_dispute_case_pivot" model="ir.ui.view">
      <field name="name">collection.dispute.case.pivot</field>
      <field name="model">collection.dispute.case</field>
      <field name="arch" type="xml">
        <pivot string="Analyse Recouvrements">
          <!-- Mesures (somme par défaut) -->
          <field name="loan_amount" type="measure"/>
          <field name="remaining_amount" type="measure"/>
          <field name="provisional_arrears" type="measure"/>
          <field name="final_arrears" type="measure"/>
          <field name="total_recovered" type="measure"/>
          <field name="total_additional_fees" type="measure"/>
          <field name="total_honorary" type="measure"/>
          <field name="total_procedure_fee" type="measure"/>

          <!-- Dimensions / group by -->
          <field name="case_manager_id"/>
          <field name="customer_id"/>
          <field name="country_id"/>
          <field name="workflow_id"/>
          <field name="creation_date" interval="month"/>
        </pivot>
      </field>
    </record>

    <!-- ====== GRAPH ====== -->
    <record id="view_collection_dispute_case_graph" model="ir.ui.view">
      <field name="name">collection.dispute.case.graph</field>
      <field name="model">collection.dispute.case</field>
      <field name="arch" type="xml">
        <graph string="Graphique Recouvrements" type="bar" stacked="True">
          <!-- Mesure par défaut -->
          <field name="total_recovered" type="measure"/>
          <!-- Axe X / groupements -->
          <field name="creation_date" interval="month"/>
          <field name="case_manager_id" group="True"/>
        </graph>
      </field>
    </record>

    <!-- ====== ACTIVITY ====== -->
    <record id="view_collection_dispute_case_activity" model="ir.ui.view">
      <field name="name">collection.dispute.case.activity</field>
      <field name="model">collection.dispute.case</field>
      <field name="arch" type="xml">
        <activity string="Activités"/>
      </field>
    </record>


    <record id="action_collection_dispute_case" model="ir.actions.act_window">
        <field name="name">Recouvrements</field>
        <field name="res_model">collection.dispute.case</field>
      <field name="view_mode">list,kanban,calendar,pivot,graph,activity,form</field>
    </record>

    <menuitem name="Recouvrements" 
        id="collection_dispute_base_menu" 
        parent="menu_collection_disputes_base_root"
        action="action_collection_dispute_case" 
        sequence="1"/>
   </data>
</odoo>
