<odoo>

    <record id="view_collateral_type_tree" model="ir.ui.view">
        <field name="name">collateral.type.list</field>
        <field name="model">collection_disputes_base.collateral_type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="is_transferable"/>
            </list>
        </field>
    </record>

    <record id="action_collateral_type" model="ir.actions.act_window">
        <field name="name">Types de garantie</field>
        <field name="res_model">collection_disputes_base.collateral_type</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem 
        id="menu_collateral_type" 
        name="Types de garantie" 
        parent="menu_configuration" 
        action="action_collateral_type"/>
</odoo>
