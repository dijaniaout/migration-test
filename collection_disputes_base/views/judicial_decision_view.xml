<odoo>
    <!-- Action -->
    <record id="action_judicial_decision" model="ir.actions.act_window">
        <field name="name">Décisions de justice</field>
        <field name="res_model">collection_disputes_base.judicial_decision</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- List view -->
    <record id="view_judicial_decision_tree" model="ir.ui.view">
        <field name="name">collection_disputes_base.judicial_decision.list</field>
        <field name="model">collection_disputes_base.judicial_decision</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="decision_date"/>
                <field name="instance_level"/>
                <field name="currency_id"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_judicial_decision_form" model="ir.ui.view">
        <field name="name">collection_disputes_base.judicial_decision.form</field>
        <field name="model">collection_disputes_base.judicial_decision</field>
        <field name="arch" type="xml">
            <form string="Décision de justice">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="instance_level"/>
                        </group>
                        <group>
                            <field name="decision_status" widget="radio" options="{'horizontal': true}"/>
                            <field name="decision_date"/>
                            <field name="currency_id" />
                            <field name="dispute_case_id" invisible="1"/>
                            <field name="legal_dispute_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Condamnations">
                            <field name="condemnation_ids" context="{'default_decision_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="bank_claim_amount"/>
                                    <field name="counterparty_claim_amount"/>
                                    <field name="amount_condemnation"/>
                                    <field name="outcome"/>
                                    <field name="comment"/>
                                    <field name="currency_id" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Commentaires">
                            <field name="comment" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
