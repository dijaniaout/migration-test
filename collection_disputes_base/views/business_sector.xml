<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_collection_disputes_base_business_sector_form" model="ir.ui.view">
            <field name="name">collection_disputes_base.business_sector.form</field>
            <field name="model">collection_disputes_base.business_sector</field>
            <field name="arch" type="xml">
                <form string="Secteur d'activité">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_collection_disputes_base_business_sector_tree" model="ir.ui.view">
            <field name="name">collection_disputes_base.business_sector.list</field>
            <field name="model">collection_disputes_base.business_sector</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="collection_dispute_management_business_sector_action" model="ir.actions.act_window">
            <field name="name">Secteurs d'activité</field>
            <field name="res_model">collection_disputes_base.business_sector</field>
            <field name="view_mode">list</field>
        </record>
        <menuitem 
            name="Secteurs d'activité" 
            id="collection_dispute_management_business_sector_menu" 
            parent="menu_configuration" 
            action="collection_dispute_management_business_sector_action"/>
    </data>
</odoo>