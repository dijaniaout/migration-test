<odoo>
    <data>

        <!-- List View -->
        <record id="view_negotiation_limit_rule_tree" model="ir.ui.view">
            <field name="name">negotiation.limit.rule.list</field>
            <field name="model">collection_disputes_base.negotiation_limit_rule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="justification_required"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_negotiation_limit_rule_form" model="ir.ui.view">
            <field name="name">negotiation.limit.rule.form</field>
            <field name="model">collection_disputes_base.negotiation_limit_rule</field>
            <field name="arch" type="xml">
                <form string="Règle de négociation">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="justification_required"/>
                            </group>    
                        </group>
                        <notebook>
                            <page string="Lignes de règle">
                                <field name="line_ids">
                                    <list editable="bottom" create="false">
                                        <field name="condition_type"/>
                                        <field name="max_percentage"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_negotiation_limit_rule" model="ir.actions.act_window">
            <field name="name">Règles de Limite</field>
            <field name="res_model">collection_disputes_base.negotiation_limit_rule</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem id="menu_negotiation_limit_rule"
                name="Règles des Limites"
                parent="menu_configuration"
                action="action_negotiation_limit_rule"/>
    </data>

</odoo>