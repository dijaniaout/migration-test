<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- ============ VUE TREE ============ -->
        <record id="view_amortization_line_tree" model="ir.ui.view">
            <field name="name">collection_disputes_base.amortization_line.list</field>
            <field name="model">collection_disputes_base.amortization_line</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="agreement_id" optional="hide"/>
                    <field name="currency_id" optional="hide" />
                    <field name="date" widget="date"/>
                    <field name="amount" sum="Total à rembourser"/>
                    <field name="paid_amount" sum="Total payé"/>
                    <field name="principal" sum="Total principal"/>
                    <field name="interest" sum="Total intérêts"/>
                    <field name="remaining_principal"/>
                    <field name="payment_ref"/>
                    <field name="payment_date" widget="date"/>
                    <field name="status" widget="statusbar"/>
                    <field name="currency_id" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- ============ VUE FORM ============ -->
        <record id="view_amortization_line_form" model="ir.ui.view">
            <field name="name">collection_disputes_base.amortization_line.form</field>
            <field name="model">collection_disputes_base.amortization_line</field>
            <field name="arch" type="xml">
                <form string="Ligne d'amortissement">
                    <sheet>
                        <header>
                            <field name="status"  widget="statusbar" options="{'clickable': '1'}" />
                        </header>
                        <group>
                            <group string="Informations générales">
                                <field name="agreement_id" invisible="1"/>
                                <field name="date"/>
                                <field name="principal"/>
                                <field name="interest"/>
                                <field name="amount"/>
                            </group>

                            <group string="Suivi du paiement">
                                <field name="paid_amount"/>
                                <field name="payment_ref"/>
                                <field name="payment_date"/>
                                <field name="remaining_principal" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Documents de paiement">
                                <field name="attachment_ids" widget="many2many_binary"  options="{'filename': 'name'}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============ ACTION ============ -->
        <record id="action_amortization_line" model="ir.actions.act_window">
            <field name="name">Echéances / Paiements</field>
            <field name="res_model">collection_disputes_base.amortization_line</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_amortization_line_tree"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créez et suivez ici les échéances de remboursement issues des accords transactionnels.
                </p>
            </field>
        </record>

    </data>
</odoo>
