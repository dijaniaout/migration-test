<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- Form View -->
        <record id="view_payment_incident_form" model="ir.ui.view">
            <field name="name">payment.incident.form</field>
            <field name="model">payment.incident</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_code" />                            
                                 <field name="payment_nature_id"/>
                                 <field name="issuing_bank"/>
                                 <field name="dispute_case_id" />
                            </group>
                           <group>
                                <field name="name"/>
                                <field name="reception_date"/>
                                <field name="amount"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="view_payment_incident_tree" model="ir.ui.view">
            <field name="name">payment.incident.list</field>
            <field name="model">payment.incident</field>
            <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_code"/>
                <field name="payment_nature_id"/>
                <field name="reception_date"/>
                <field name="amount"/>
                <field name="issuing_bank"/>
            </list>
            </field>
        </record>

        <!-- Action to open the list view -->
        <record id="action_payment_incident" model="ir.actions.act_window">
            <field name="name">Incident de Paiement</field>
            <field name="res_model">payment.incident</field>
            <field name="view_mode">list,form</field>
        </record>

       <menuitem id="payment_incident_menu" name="Incident de Paiement" parent="menu_collection_disputes_management_root" sequence="1" action="action_payment_incident"/>
        
    </data>

</odoo>
