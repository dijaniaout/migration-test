<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- Form View -->
        <record id="view_loan_settlement_statement_form" model="ir.ui.view">
            <field name="name">loan.settlement.statement.form</field>
            <field name="model">loan.settlement.statement</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="disbursed_amount"/>
                                <field name="statement_date"/>
                                <field name="statement_type"/>
                                 <field name="principal_due"/>
                                <field name="total_due" />
                            </group>
                           <group>
                                <field name="commitment_fees"/>
                                <field name="agf_fees"/>
                                <field name="other_fees"/>
                                <field name="interest_due"/>
                                <field name="late_interest"/>
                            </group>
                        </group>
                        <!-- Zone d’upload de fichiers dans la modale -->
                        <group string="Pièces jointes">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="view_loan_settlement_statement_tree" model="ir.ui.view">
            <field name="name">loan.settlement.statement.list</field>
            <field name="model">loan.settlement.statement</field>
            <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="disbursed_amount"/>
                <field name="statement_type"/>
                <field name="statement_date"/>
                <field name="principal_due"/>
                <field name="commitment_fees"/>
                <field name="agf_fees"/>
                <field name="other_fees"/>
                <field name="interest_due"/>
                 <field name="late_interest"/>
                <field name="total_due"/>
                <field name="currency_id" optional="hide"/>
            </list>
            </field>
        </record>

        <!-- Action to open the list view -->
        <record id="action_loan_settlement_statement" model="ir.actions.act_window">
            <field name="name">Arrêtés de Prêt</field>
            <field name="res_model">loan.settlement.statement</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem 
            name="Arrêtés de Prêt" 
            id="loan_settlement_statemen_menu" 
            parent="menu_stakeholders" 
            action="action_loan_settlement_statement"/>
        
    </data>

</odoo>
