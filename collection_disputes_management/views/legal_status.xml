<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_collection_disputes_management_legal_status_form" model="ir.ui.view">
            <field name="name">collection_disputes_management.legal_status.form</field>
            <field name="model">collection_disputes_management.legal_status</field>
            <field name="arch" type="xml">
                <form string="Forme juridique">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_collection_disputes_management_legal_status_tree" model="ir.ui.view">
            <field name="name">collection_disputes_management.legal_status.list</field>
            <field name="model">collection_disputes_management.legal_status</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="collection_dispute_management_legal_status_action" model="ir.actions.act_window">
            <field name="name">Formes juridique</field>
            <field name="res_model">collection_disputes_management.legal_status</field>
            <field name="view_mode">list</field>
        </record>
        <menuitem 
            name="Formes juridiques" 
            id="collection_dispute_management_legal_status_menu" 
            parent="menu_configuration" 
            action="collection_dispute_management_legal_status_action"/>
    </data>
</odoo>