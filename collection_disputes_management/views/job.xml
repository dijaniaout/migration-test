<odoo>
    <record id="view_collection_disputes_management_job_form" model="ir.ui.view">
        <field name="name">collection_disputes_management.job.form</field>
        <field name="model">collection_disputes_management.job</field>
        <field name="arch" type="xml">
            <form string="Métier">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_collection_disputes_management_job_tree" model="ir.ui.view">
        <field name="name">collection_disputes_management.job.list</field>
        <field name="model">collection_disputes_management.job</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="collection_dispute_management_job_action" model="ir.actions.act_window">
        <field name="name">Métiers</field>
        <field name="res_model">collection_disputes_management.job</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem 
        name="Métiers" 
        id="collection_dispute_management_job" 
        parent="menu_configuration" 
        action="collection_dispute_management_job_action"/>
</odoo>