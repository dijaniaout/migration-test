<odoo>

    <record id="view_legal_dispute_type_tree" model="ir.ui.view">
        <field name="name">legal_dispute_type.list</field>
        <field name="model">collection_disputes_management.legal_dispute_type</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_legal_dispute_type" model="ir.actions.act_window">
        <field name="name">Types de litiges</field>
        <field name="res_model">collection_disputes_management.legal_dispute_type</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem 
        id="menu_legal_dispute_type" 
        name="Types de litiges" 
        parent="menu_configuration" 
        action="action_legal_dispute_type"/>
</odoo>
