<odoo>    
    <data>
        <record id="document_to_validate_access_manager_portal" model="ir.rule">
            <field name="name">Document to validate rights: Portal</field>
            <field name="model_id" ref="model_customisable_workflow_validation_work_doc_to_validate"/>
            <field name="domain_force">[('origin_id.allowed_group_ids','in',user.group_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>    
</odoo>            